<div id="cloudflare-header"></div>
<script>
  fetch('https://1e0d8781.ldc-site-scripts.pages.dev/header.html')
    .then(response => response.text())
    .then(html => {
      // Insert the HTML/CSS
      document.getElementById('cloudflare-header').innerHTML = html;
      
      // Extract and execute the script
      const scriptContent = html.match(/<script>([\s\S]*?)<\/script>/);
      if (scriptContent && scriptContent[1]) {
        eval(scriptContent[1]);
      }
    });
</script>